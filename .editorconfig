root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
# Require braces on all control-flow statements (if/else, for, foreach, while,
# using, lock, fixed, etc.), including single-line bodies.
csharp_prefer_braces = true
dotnet_diagnostic.IDE0011.severity = warning
