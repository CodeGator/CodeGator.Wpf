<Window x:Class="Sample1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:cg="clr-namespace:CodeGator.Wpf;assembly=CodeGator.Wpf"
        mc:Ignorable="d"
        Title="Sample1 - CodeGator.Wpf" Height="720" Width="1120"
        Background="#0D0D0F">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="#111115" Padding="12" BorderBrush="#25252C" BorderThickness="0,0,0,1">
            <TextBlock Text="CodeGator.Wpf controls" Foreground="#F0F0F2" FontSize="16" FontWeight="SemiBold" />
        </Border>

        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#16161A"
                    BorderBrush="#25252C"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10,8"
                    Margin="0,0,0,8">
                <StackPanel>
                    <WrapPanel VerticalAlignment="Center">
                        <TextBlock Text="Zoom" Foreground="#F0F0F2" VerticalAlignment="Center" Margin="0,0,8,6" />
                        <Slider Width="160"
                                Minimum="0.25"
                                Maximum="4"
                                SmallChange="0.05"
                                LargeChange="0.25"
                                Value="{Binding ZoomForce, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Margin="0,0,10,6"
                                VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ZoomForce, StringFormat={}{0:0.00}x}"
                                   Foreground="#F0F0F2"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,6" />

                        <Button Content="Reset view" Padding="10,6" Click="ResetViewForce_Click" Margin="0,0,8,6" />
                        <Button Content="Print…" Padding="10,6" Click="PrintForce_Click" Margin="0,0,8,6" />
                        <Button Content="Load sample graph" Padding="10,6" Click="LoadSampleGraphForce_Click" Margin="0,0,8,6" />
                    </WrapPanel>
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding ForceLastEvent}"
                               Foreground="#9EC9FF"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>

            <cg:CgDiagram x:Name="Diagram"
                                       Grid.Row="1"
                                       Nodes="{Binding NodesForce}"
                                       Edges="{Binding EdgesForce}"
                                       Zoom="{Binding ZoomForce, Mode=TwoWay}"
                                       MinZoom="0.25"
                                       MaxZoom="6"
                                       PanX="{Binding PanXForce, Mode=TwoWay}"
                                       PanY="{Binding PanYForce, Mode=TwoWay}"
                                       ShowGrid="False"
                                       GridOpacity="0.35"
                                       EdgeThickness="1.25" />
        </Grid>
    </DockPanel>
</Window>
