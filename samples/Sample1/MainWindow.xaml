<Window x:Class="Sample1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sample1"
        xmlns:cg="clr-namespace:CodeGator.Wpf;assembly=CodeGator.Wpf"
        mc:Ignorable="d"
        Title="Sample1 - CgDiagram" Height="720" Width="1120"
        Background="#0D0D0F">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="#111115" Padding="12" BorderBrush="#25252C" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="CgDiagram (CodeGator.Wpf)" Foreground="#F0F0F2" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Margin="0,4,0,0"
                               Text="Left-drag nodes. Mouse wheel zoom. Right-drag pan."
                               Foreground="#B8B8C2" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding LastEvent}"
                               Foreground="#9EC9FF"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <CheckBox Content="Grid"
                              IsChecked="{Binding ShowGrid}"
                              Margin="0,0,14,0"
                              Foreground="#F0F0F2" />

                    <TextBlock Text="Zoom" Foreground="#F0F0F2" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Slider Width="160"
                            Minimum="0.25"
                            Maximum="4"
                            SmallChange="0.05"
                            LargeChange="0.25"
                            Value="{Binding Zoom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Margin="0,0,10,0" />
                    <TextBlock Text="{Binding Zoom, StringFormat={}{0:0.00}x}"
                               Foreground="#F0F0F2"
                               VerticalAlignment="Center"
                               Margin="0,0,14,0" />

                    <TextBlock Text="Layout" Foreground="#F0F0F2" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox Width="220"
                              ItemsSource="{Binding AvailableLayouts}"
                              SelectedItem="{Binding Layout}"
                              SelectionChanged="Layout_SelectionChanged"
                              Margin="0,0,14,0" />

                    <Button Content="Reset view" Padding="10,6" Click="ResetView_Click" Margin="0,0,10,0" />
                    <Button Content="Print…" Padding="10,6" Click="Print_Click" Margin="0,0,10,0" />
                    <Button Content="Load sample graph" Padding="10,6" Click="LoadSampleGraph_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="12">
            <cg:CgDiagram x:Name="Diagram"
                         Nodes="{Binding Nodes}"
                         Edges="{Binding Edges}"
                         Zoom="{Binding Zoom, Mode=TwoWay}"
                         MinZoom="0.25"
                         MaxZoom="6"
                         PanX="{Binding PanX, Mode=TwoWay}"
                         PanY="{Binding PanY, Mode=TwoWay}"
                         ShowGrid="{Binding ShowGrid}"
                         GridOpacity="0.35"
                         EdgeThickness="1.25"
                         Layout="{Binding Layout}"
                         NodeClick="Diagram_NodeClick"
                         NodeRightClick="Diagram_NodeRightClick"
                         EdgeClick="Diagram_EdgeClick"
                         EdgeRightClick="Diagram_EdgeRightClick" />
        </Grid>
    </DockPanel>
</Window>
