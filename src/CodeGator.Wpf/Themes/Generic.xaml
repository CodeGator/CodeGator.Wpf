<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:CodeGator.Wpf"
    xmlns:svg="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
    xmlns:conv="clr-namespace:CodeGator.Wpf.Converters">

    <BooleanToVisibilityConverter x:Key="BoolToVis" />
    <conv:CgSvgSourceToUriConverter x:Key="SvgSourceToUri" />
    <conv:CgPathDataToGeometryConverter x:Key="PathDataToGeometry" />

    <Style TargetType="{x:Type local:CgDiagram}">
        <Setter Property="Background" Value="#0D0D0F" />
        <Setter Property="Foreground" Value="#F0F0F2" />
        <Setter Property="NodeSize" Value="168,88" />
        <Setter Property="ContentPadding" Value="40" />
        <Setter Property="GridBrush">
            <Setter.Value>
                <DrawingBrush TileMode="Tile"
                              Viewport="0,0,40,40"
                              ViewportUnits="Absolute"
                              Viewbox="0,0,40,40"
                              ViewboxUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <DrawingGroup>
                            <GeometryDrawing Brush="Transparent">
                                <GeometryDrawing.Pen>
                                    <Pen Brush="#22FFFFFF" Thickness="1" />
                                </GeometryDrawing.Pen>
                                <GeometryDrawing.Geometry>
                                    <GeometryGroup>
                                        <LineGeometry StartPoint="40,0" EndPoint="40,40" />
                                        <LineGeometry StartPoint="0,40" EndPoint="40,40" />
                                    </GeometryGroup>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingGroup>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="NodeTemplate">
            <Setter.Value>
                <DataTemplate DataType="{x:Type local:CgDiagramNode}">
                    <Grid x:Name="Root"
                          Width="{Binding Width}"
                          Height="{Binding Height}"
                          MinWidth="140"
                          MinHeight="72"
                          SnapsToDevicePixels="True">

                        <!-- Surface node (default): chrome fills cell; text is separate layer -->
                        <Border x:Name="SurfaceChrome"
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Stretch"
                                BorderThickness="1"
                                CornerRadius="10"
                                Background="#17171B"
                                BorderBrush="#2B2B33" />

                        <!-- SVG path node: uniform scale so geometry is not stretched tall/wide -->
                        <Viewbox x:Name="SvgPathNode"
                                 Visibility="Collapsed"
                                 Stretch="Uniform"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Margin="4">
                            <Grid Width="100" Height="100">
                                <Path x:Name="SvgPathShape"
                                      Data="{Binding SvgPathData, Converter={StaticResource PathDataToGeometry}}"
                                      Fill="#17171B"
                                      Stroke="#2B2B33"
                                      StrokeThickness="1"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                            </Grid>
                        </Viewbox>

                        <!-- SVG file node: same uniform scaling and centering -->
                        <Viewbox x:Name="SvgFileNode"
                                 Visibility="Collapsed"
                                 Stretch="Uniform"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 Margin="4">
                            <Grid Width="100" Height="100">
                                <svg:SvgCanvas x:Name="SvgFileShape"
                                               Width="100"
                                               Height="100"
                                               Source="{Binding SvgSource, Converter={StaticResource SvgSourceToUri}}"
                                               AutoSize="False" />
                            </Grid>
                        </Viewbox>

                        <!-- Text: centered in node; stretch constrains wrap width so text stays inside bounds -->
                        <Border x:Name="TextLayer"
                                Background="Transparent"
                                Padding="12,10"
                                Margin="10,8"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Stretch">
                            <StackPanel>
                                <TextBlock Text="{Binding Label}"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:CgDiagram}}, Path=Foreground}" />
                                <TextBlock Text="{Binding Description}"
                                           Opacity="0.75"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Margin="0,4,0,0"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:CgDiagram}}, Path=Foreground}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding Presentation}" Value="{x:Static local:CgDiagramNodePresentation.Surface}">
                            <Setter TargetName="SurfaceChrome" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SvgPathNode" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SvgFileNode" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Presentation}" Value="{x:Static local:CgDiagramNodePresentation.SvgPath}">
                            <Setter TargetName="SurfaceChrome" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SvgPathNode" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SvgFileNode" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Presentation}" Value="{x:Static local:CgDiagramNodePresentation.SvgFile}">
                            <Setter TargetName="SurfaceChrome" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SvgPathNode" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SvgFileNode" Property="Visibility" Value="Visible" />
                        </DataTrigger>

                        <DataTrigger Binding="{Binding IsHovered}" Value="True">
                            <Setter TargetName="SurfaceChrome" Property="BorderBrush" Value="#55FFFFFF" />
                            <Setter TargetName="SurfaceChrome" Property="Background" Value="#1C1C22" />
                            <Setter TargetName="SvgPathShape" Property="Stroke" Value="#55FFFFFF" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter TargetName="SurfaceChrome" Property="BorderBrush" Value="DeepSkyBlue" />
                            <Setter TargetName="SurfaceChrome" Property="Background" Value="#1A2230" />
                            <Setter TargetName="SvgPathShape" Property="Stroke" Value="DeepSkyBlue" />
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:CgDiagram}">
                    <Border Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Rectangle Fill="{TemplateBinding Background}" />
                            <Rectangle Fill="{TemplateBinding GridBrush}"
                                       Opacity="{TemplateBinding GridOpacity}"
                                       Visibility="{Binding ShowGrid, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BoolToVis}}" />

                            <ScrollViewer x:Name="PART_ScrollViewer"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          CanContentScroll="False"
                                          Background="Transparent">
                                <!-- Content area with zoom/pan transforms -->
                                <Grid x:Name="PART_ContentGrid"
                                      Width="{Binding ContentWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                      Height="{Binding ContentHeight, RelativeSource={RelativeSource TemplatedParent}}">
                                    <!-- Use LayoutTransform for zoom so ScrollViewer measures scaled extent -->
                                    <Grid.LayoutTransform>
                                        <ScaleTransform ScaleX="{Binding Zoom, RelativeSource={RelativeSource TemplatedParent}}"
                                                        ScaleY="{Binding Zoom, RelativeSource={RelativeSource TemplatedParent}}" />
                                    </Grid.LayoutTransform>

                                    <!-- Keep panning as a render-time translation -->
                                    <Grid.RenderTransform>
                                        <TranslateTransform X="{Binding PanX, RelativeSource={RelativeSource TemplatedParent}}"
                                                            Y="{Binding PanY, RelativeSource={RelativeSource TemplatedParent}}" />
                                    </Grid.RenderTransform>

                                    <Canvas x:Name="PART_EdgesCanvas" IsHitTestVisible="False" />

                                    <ItemsControl x:Name="PART_NodesItems"
                                                  ItemsSource="{TemplateBinding Nodes}"
                                                  ItemTemplate="{TemplateBinding NodeTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding Position.X}" />
                                                <Setter Property="Canvas.Top" Value="{Binding Position.Y}" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                    </ItemsControl>
                                </Grid>
                            </ScrollViewer>

                            <!-- Overlay for selection rectangle and future adorners -->
                            <Canvas x:Name="PART_OverlayCanvas"
                                    IsHitTestVisible="False" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

